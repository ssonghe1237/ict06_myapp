<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="spring.ict06team1.midpj.dao.AdPlaceDAO">
	<!-- 축제 조회 -->
	<!-- 축제에 필요한 변수 매핑 -->
	<resultMap id="festivalMap" type="spring.ict06team1.midpj.dto.FestivalDTO">
	 	<id property="festival_id" column="festival_id"/>
	 	<result property="description" column="description"/>
	 	<result property="start_date" column="start_date"/>
	 	<result property="end_date" column="end_date"/>
	 	<result property="status" column="status"/>
	 	
	 	<association property="placeDTO" javaType="spring.ict06team1.midpj.dto.PlaceDTO">
	 		<id property="place_id" column="place_id"></id>
	 		<result property="place_type" column="place_type"></result>
	 		<result property="name" column="name"></result>
	 		<result property="address" column="address"></result>
	 		<result property="view_count" column="view_count"></result>
	 		<result property="latitude" column="latitude"></result>
	 		<result property="longitude" column="longitude"></result>
	 		<result property="image_url" column="image_url"></result>
	 		<result property="placeRegDate" column="created_at"></result>
	 		<result property="placeUpdateDate" column="updated_at"></result>
	 	</association>
	</resultMap>
	
	<!-- 축제 목록 조회 -->
	<select id="getFestivalList" parameterType="map" resultMap="festivalMap">
		SELECT *
		  FROM PLACE p
		  JOIN FESTIVAL f 
		    ON p.place_id = f.festival_id;
	</select>
	
	<!-- 축제 상세 정보 조회 -->
	
